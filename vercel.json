{
  "redirects": [
    {
      "source": "/blog/:path*",
      "has": [{ "type": "host", "value": "bookpublishingservices.io" }],
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog$",
      "destination": "https://darkviolet-jellyfish-929687.hostingersite.com/"
    },
    {
      "source": "/(the|how|why|book|author|publisher|writing|editing|publishing|marketing|branding|story|novel|read|print|distribution|promotion|review|audiobook|ebook|manuscript|design|cover|service|help|process|genre|bookstore|bestseller|publish)/:path*",
      "destination": "https://darkviolet-jellyfish-929687.hostingersite.com/:path*"
    }
  ]
}